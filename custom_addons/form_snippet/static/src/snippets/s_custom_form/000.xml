<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <!-- Definiujemy nasz typ pola -->
    <t t-name="website.form_field_range">
        <!-- Używamy natywnego opakowania Odoo, które obsługuje Position/Description -->
        <t t-call="website.form_field">
            <input
                type="range"
                class="form-range s_website_form_input"
                t-att-name="field.name"
                t-att-required="field.required || field.modelRequired || None"
                t-att-id="field.id"
                min="0" max="100" step="10" 
                t-att-value="field.value or 50"
            />
            <!-- Nasz customowy element do wyświetlania wartości -->
            <div class="slider-value-display text-center fw-bold fs-4 mt-2 text-primary">
                <t t-esc="field.value or 50"/>
            </div>
        </t>
    </t>
</templates>