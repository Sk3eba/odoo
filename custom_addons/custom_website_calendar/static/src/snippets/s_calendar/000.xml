<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="custom_website_calendar.calendar_template">
        <div class="s_calendar_wrapper">
            
            <!-- Nagłówek kalendarza -->
            <div class="calendar-header d-flex justify-content-between align-items-center mb-3">
                <button class="btn btn-outline-primary btn-sm btn-prev-month">
                    <i class="fa fa-chevron-left"/> Previous
                </button>
                <h4 class="m-0 fw-bold">
                    <t t-esc="monthName"/> <t t-esc="year"/>
                </h4>
                <button class="btn btn-outline-primary btn-sm btn-next-month">
                    Next <i class="fa fa-chevron-right"/>
                </button>
            </div>

            <!-- Tabela kalendarza -->
            <table class="table table-bordered text-center s_calendar_table w-100 bg-white mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th><th>Sun</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="weeks" t-as="week" t-key="week_index">
                        <td t-foreach="week" t-as="day" t-key="day_index" 
                            t-attf-class="calendar-day-cell {{ day.is_current_month ? '' : 'text-muted bg-light opacity-50' }} {{ day.events.length ? 'bg-danger-subtle fw-bold' : '' }}"
                            t-att-data-date="day.full_date"
                            style="cursor: pointer; height: 80px; vertical-align: middle;">
                            
                            <div class="d-flex flex-column h-100 justify-content-between">
                                <span class="align-self-start" t-esc="day.day_num"/>
                                <div t-if="day.events.length" class="align-self-end d-flex gap-1 justify-content-center flex-wrap mb-1">
                                    <t t-foreach="day.events" t-as="dotEv" t-key="dotEv.id">
                                        <span class="rounded-circle bg-danger" style="width: 8px; height: 8px; display: inline-block;" t-att-title="dotEv.name"></span>
                                    </t>
                                </div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- MODAL DO ZARZĄDZANIA WYDARZENIAMI -->
            <div class="modal fade" id="calendarAddEventModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Events on: <span id="modalDisplayDate" class="fw-bold text-primary"></span></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <!-- Lista istniejących wydarzeń na dany dzień -->
                            <div class="mb-3">
                                <h6 class="text-muted small uppercase fw-bold">Planned events:</h6>
                                <ul id="modalEventsList" class="list-group mb-3">
                                    <!-- Dynamicznie uzupełniane przez JS -->
                                </ul>
                            </div>

                            <hr/>

                            <!-- Formularz dodawania nowego wydarzenia -->
                            <div class="mb-3">
                                <label for="eventNameInput" class="form-label fw-bold">Add new event</label>
                                <input type="text" class="form-control" id="eventNameInput" placeholder="Enter new event..."/>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <button type="button" class="btn btn-primary btn-save-event" id="saveEventBtn">Save event</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </t>
</templates>