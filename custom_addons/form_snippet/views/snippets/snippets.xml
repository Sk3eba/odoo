<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="snippets" inherit_id="website.snippets" name="Custom Form - Snippets">
        <xpath expr="//snippets[@id='snippet_content']/*[1]" position="before">
            <t t-snippet="form_snippet.s_custom_form" string="Custom Form" t-thumbnail="/web/static/img/placeholder.png"/>
        </xpath>
    </template>
</odoo>