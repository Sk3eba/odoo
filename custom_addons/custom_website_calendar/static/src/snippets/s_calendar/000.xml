<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="custom_website_calendar.calendar_template">
        <!-- SINGLE ROOT NODE ADDED HERE -->
        <div class="s_calendar_wrapper"> 
            
            <div class="calendar-header d-flex justify-content-between align-items-center mb-3">
                <button class="btn btn-outline-primary btn-sm btn-prev-month">
                    <i class="fa fa-chevron-left"/> Previous
                </button>
                <h4 class="m-0 fw-bold">
                    <t t-esc="monthName"/> <t t-esc="year"/>
                </h4>
                <button class="btn btn-outline-primary btn-sm btn-next-month">
                    Next <i class="fa fa-chevron-right"/>
                </button>
            </div>

            <table class="table table-bordered text-center s_calendar_table w-100 bg-white mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th><th>Sun</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="weeks" t-as="week" t-key="week_index">
                        <td t-foreach="week" t-as="day" t-key="day_index" 
                            t-attf-class="calendar-day-cell {{ day.is_current_month ? '' : 'text-muted bg-light opacity-50' }}"
                            t-att-data-date="day.full_date">
                            <strong t-esc="day.day_num"/>
                            
                            <div t-if="day.events.length" class="mt-1">
                                <t t-foreach="day.events" t-as="event" t-key="event.id">
                                    <span class="badge text-bg-primary d-block text-truncate mb-1" 
                                          t-att-title="event.description">
                                        <t t-esc="event.name"/>
                                    </span>
                                </t>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="modal fade" id="calendarAddEventModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Zarządzaj wydarzeniem (<span id="modalDisplayDate"></span>)</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="eventNameInput" class="form-label">Nazwa wydarzenia</label>
                                <input type="text" class="form-control" id="eventNameInput" placeholder="Wpisz nazwę..."/>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zamknij</button>
                            <button type="button" class="btn btn-primary btn-save-event" id="saveEventBtn">Zapisz wydarzenie</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>