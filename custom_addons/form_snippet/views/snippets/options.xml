<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_field_type_slider" inherit_id="website.snippet_options" name="Custom Form Options">
        <xpath expr="//we-select[@data-name='type_opt']" position="inside">
            <we-button data-custom-field="range">Slider / Suwak</we-button>
        </xpath>
        
        <xpath expr="." position="inside">
            <div data-js="CustomSlider" data-selector=".s_website_form_field[data-type='range']" string="Ustawienia Suwaka">
                <we-input string="Minimum" data-select-data-attribute="" data-attribute-name="min" placeholder="np. 0"/>
                <we-input string="Maksimum" data-select-data-attribute="" data-attribute-name="max" placeholder="np. 100"/>
                <we-input string="Skok (Step)" data-select-data-attribute="" data-attribute-name="step" placeholder="np. 10"/>
                <we-input string="Wartość startowa" data-select-data-attribute="" data-attribute-name="value" placeholder="np. 50"/>
                
                <!-- Opcje pozycjonowania (nadają klasy na całe pole) -->
                <we-select string="Pozycja wartości" data-no-preview="true">
                    <we-button data-select-class="">Ukryta</we-button>
                    <we-button data-select-class="s_slider_value_top">Góra</we-button>
                    <we-button data-select-class="s_slider_value_bottom">Dół</we-button>
                    <we-button data-select-class="s_slider_value_left">Lewo</we-button>
                    <we-button data-select-class="s_slider_value_right">Prawo</we-button>
                </we-select>
            </div>
        </xpath>
    </template>
</odoo>